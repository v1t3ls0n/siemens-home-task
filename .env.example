# --- LLM providers (set the ones your routing config uses) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...        # only if anthropic appears in routing
OLLAMA_BASE_URL=http://localhost:11434   # only for local models

# --- OpenSearch (docker-compose default) ---
OPENSEARCH_URL=http://localhost:9200

# --- Misc ---
AGENTS_TRACING=0        # 1 = send traces to OpenAI platform (needs OPENAI_API_KEY)
CONFIG_PATH=config.yaml
